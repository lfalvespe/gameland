rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Primitive Definitions
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'player') == 'admin') ||
        (request.auth.token.email == "lfalvespe@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    function isModerator() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'player') == 'moderator') || 
        isAdmin()
      );
    }
    function isBanned() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('banned', false) == true;
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Collection: test
    // ===============================================================
    match /test/connection {
      allow get: if isSignedIn();
    }

    // ===============================================================
    // Collection: users
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'displayName_normalized', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 64 &&
             data.displayName_normalized is string && data.displayName_normalized.size() > 0 && data.displayName_normalized.size() <= 64 &&
             data.email is string && data.email.size() <= 128;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    (!('role' in incoming()) || incoming().role == 'player') &&
                    (!('banned' in incoming()) || incoming().banned == false);
      allow update: if (isOwner(userId) && (
        // Prevent privilege escalation or self-unbanning
        incoming().get('role', 'player') == existing().get('role', 'player') &&
        incoming().get('banned', false) == existing().get('banned', false) &&
        incoming().uid == existing().uid &&
        (!('score' in incoming()) || (incoming().score is number && incoming().score >= 0))
      )) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ===============================================================
    // Collection: friendships
    // ===============================================================
    function isValidFriendship(data) {
      return data.keys().hasAll(['users', 'status', 'createdAt']) &&
             data.users is list && data.users.size() == 2 &&
             data.users[0] is string && data.users[1] is string &&
             data.status in ['pending', 'accepted', 'rejected'];
    }

    match /friendships/{friendshipId} {
      allow get: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid in resource.data.users ||
        request.auth.uid in friendshipId.split('_')
      );
      allow list: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid in resource.data.users
      );
      allow create: if isSignedIn() && isValidId(friendshipId) && isValidFriendship(incoming()) && 
                    request.auth.uid in incoming().users && 
                    incoming().status == 'pending';
      allow update: if isSignedIn() && (request.auth.uid in existing().users || isAdmin());
      allow delete: if isAdmin() || isModerator();
    }

    // ===============================================================
    // Collection: matches
    // ===============================================================
    match /matches/{matchId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid in incoming().players;
      allow delete: if isAdmin() || isModerator();
    }

    // ===============================================================
    // Collection: rooms
    // ===============================================================
    function isValidRoom(data) {
      return data.keys().hasAll(['name', 'type', 'participants', 'status']) &&
             data.name is string && data.name.size() <= 100 &&
             data.type in ['open', 'private'] &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.participants is list && data.participants.size() <= 10;
    }

    match /rooms/{roomId} {
      allow get: if isSignedIn() && (
        isAdmin() || isModerator() ||
        roomId.matches('.*' + request.auth.uid + '.*') ||
        (resource != null && (
          request.auth.uid in resource.data.participants || 
          resource.data.status == 'waiting' ||
          resource.data.type == 'open'
        ))
      );
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidRoom(incoming()) && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && (
        isAdmin() || isModerator() ||
        request.auth.uid in existing().participants || 
        existing().status == 'waiting' ||
        (existing().status == 'finished' && incoming().participants.hasAll([request.auth.uid]))
      );
      allow delete: if isAdmin() || isModerator() || (request.auth.uid in existing().participants);
    }

    // ===============================================================
    // Collection: hangman_matches
    // ===============================================================
    function isValidHangmanMatch(data) {
      return data.keys().hasAll(['players', 'status', 'playerData', 'scores', 'currentRound']) &&
             data.players is list && data.players.size() <= 6 &&
             data.status in ['setup', 'playing', 'round1_result', 'finished'] &&
             data.currentRound is number &&
             isValidId(data.players[0]) &&
             (!('word' in data) || (data.word is string && data.word.size() <= 100)) &&
             (!('hint' in data) || (data.hint is string && data.hint.size() <= 300)) &&
             (!('selectedTheme' in data) || (data.selectedTheme is string && data.selectedTheme.size() <= 100)) &&
             (!('selectedDifficulty' in data) || (data.selectedDifficulty in ['Easy', 'Medium', 'Hard'])) &&
             (!('variant' in data) || (data.variant in ['classic', 'battle']));
    }

    match /hangman_matches/{matchId} {
      allow read: if isSignedIn() && (
        isAdmin() || isModerator() ||
        resource == null || 
        request.auth.uid in resource.data.players ||
        resource.data.status == 'setup'
      );
      allow create: if isSignedIn() && 
                    isValidId(matchId) &&
                    isValidHangmanMatch(incoming()) &&
                    request.auth.uid in incoming().players;
      allow update: if isSignedIn() && (
        isAdmin() || isModerator() ||
        (request.auth.uid in existing().players && isValidHangmanMatch(incoming()) && (
          // Action: Setup (Ready/Word/Theme)
          (existing().status == 'setup' && 
           incoming().diff(existing()).affectedKeys().hasOnly(['players', 'playerData', 'status', 'startTime', 'updatedAt', 'selectedTheme', 'selectedDifficulty', 'variant', 'scores', 'currentRound'])) ||
          
          // Action: Participant Setup (Ready/Word)
          (incoming().diff(existing()).affectedKeys().hasOnly(['playerData', 'updatedAt'])) ||

          // Action: Start Game (Host Only)
          (existing().status == 'setup' && 
           incoming().status == 'playing' && 
           request.auth.uid == existing().players[0] &&
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'startTime', 'playerData', 'targetMappings', 'updatedAt', 'word', 'hint', 'selectedTheme', 'selectedDifficulty'])) ||
          
          // Action: Play/Guess/Finish
          (existing().status == 'playing' && 
           incoming().diff(existing()).affectedKeys().hasAny(['playerData', 'status', 'winner', 'finishTime', 'updatedAt']))
        )) ||
        // Action: Join during setup
        (existing().status == 'setup' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['players', 'updatedAt']) && 
         incoming().players.size() <= 6 &&
         incoming().players.hasAll(existing().players) &&
         request.auth.uid in incoming().players)
      );
      allow delete: if isAdmin() || isModerator();
    }

    // ===============================================================
    // Collection: messages
    // ===============================================================
    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'roomId']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 5000 &&
             isValidId(data.roomId);
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        existing().roomId == 'global' || 
        (!isBanned() && (
          existing().roomId.matches('.*' + request.auth.uid + '.*') || 
          existing().roomId.matches('room_.*') ||
          (exists(/databases/$(database)/documents/rooms/$(existing().roomId)) &&
           request.auth.uid in get(/databases/$(database)/documents/rooms/$(existing().roomId)).data.participants)
        ))
      );
      allow list: if isSignedIn() && (
        isAdmin() ||
        resource.data.roomId == 'global' ||
        resource.data.roomId.matches('.*' + request.auth.uid + '.*') ||
        resource.data.roomId.matches('room_.*')
      );
      allow create: if isSignedIn() && !isBanned() && isValidMessage(incoming());
      allow update: if isSignedIn() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['read']) && incoming().read == true) ||
        isAdmin()
      );
      allow delete: if isAdmin() || isModerator();
    }
  }
}
